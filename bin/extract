#!/usr/bin/env bash
# extract - universal archive extractor
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "Usage: extract <archive> [archive ...]" >&2
  exit 2
fi

for f in "$@"; do
  if [[ ! -f "$f" ]]; then
    echo "extract: '$f' does not exist" >&2
    exit 1
  fi

  case "${f,,}" in
    *.tar.gz|*.tgz)       tar xzf "$f" ;;
    *.tar.bz2|*.tbz2)     tar xjf "$f" ;;
    *.tar.xz|*.txz)       tar xJf "$f" ;;
    *.tar.zst|*.tzst)      tar --zstd -xf "$f" ;;
    *.tar)                 tar xf "$f" ;;
    *.gz)                  gunzip -k "$f" ;;
    *.bz2)                 bunzip2 -k "$f" ;;
    *.xz)                  unxz -k "$f" ;;
    *.zst)                 zstd -d "$f" ;;
    *.zip|*.jar|*.war)     unzip -o "$f" ;;
    *.7z)                  7z x "$f" ;;
    *.rar)                 unrar x "$f" ;;
    *.deb)                 ar x "$f" ;;
    *.rpm)                 rpm2cpio "$f" | cpio -idmv ;;
    *.Z)                   uncompress "$f" ;;
    *.lz)                  lzip -dk "$f" ;;
    *.lz4)                 lz4 -d "$f" ;;
    *.cab)                 cabextract "$f" ;;
    *)
      echo "extract: unknown format '$f'" >&2
      exit 1
      ;;
  esac
done
